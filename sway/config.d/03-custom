# Screenshot a region and edit with Satty
bindsym Print exec grim -g "$(slurp)" - | wl-copy
bindsym Ctrl+Print exec grim -g "$(slurp)" - | satty --filename -

# Screenshot the whole screen and edit with Satty
bindsym Shift+Print exec grim - | wl-copy
bindsym Ctrl+Shift+Print exec grim - | satty --filename -

# Clipboard manager
exec wl-paste --watch cliphist store
