# Main DP monitor
output DP-3 mode 2560x1440@144Hz position 2560 0
# Secondary DP monitor
output DP-4 mode 2560x1440@144Hz position 0 0
# Disable HDMI if not used
output HDMI-A-1 disable

# Wallpaper (requires swaybg)
output * bg /home/david/drive/Pictures/mountain.jpg fill

# Screen power management
exec swayidle -w \
    timeout 1800 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"'
